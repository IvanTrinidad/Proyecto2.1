<?xml version="1.0" encoding="UTF-8"?>
<datos xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="datos.xsd">

    <!-- ============================================================
         SEMILLAS: cada semilla tiene nombre, precio de compra,
         precio de venta, tiempo de maduracion y rutas de imagenes
         ============================================================ -->
