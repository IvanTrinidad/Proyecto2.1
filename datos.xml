    <!-- ============================================================
         HERRAMIENTAS: cada herramienta tiene 3 niveles con
         su coste de mejora y el efecto que aplica
         ============================================================ -->
    <herramientas>

        <herramienta>
            <nombre>Azada</nombre>
            <descripcion>Mejora la calidad del cultivo</descripcion>
            <niveles>
                <nivel id="1">
                    <costeUpgrade>0</costeUpgrade>
                    <bonificacion>0</bonificacion>
                    <descripcionNivel>Sin mejora</descripcionNivel>
                </nivel>
                <nivel id="2">
                    <costeUpgrade>50</costeUpgrade>
                    <bonificacion>10</bonificacion>
                    <descripcionNivel>+10% precio de venta</descripcionNivel>
                </nivel>
                <nivel id="3">
                    <costeUpgrade>120</costeUpgrade>
                    <bonificacion>25</bonificacion>
                    <descripcionNivel>+25% precio de venta</descripcionNivel>
                </nivel>
            </niveles>
        </herramienta>

        <herramienta>
            <nombre>Regadera</nombre>
            <descripcion>Reduce el tiempo de maduracion</descripcion>
            <niveles>
                <nivel id="1">
                    <costeUpgrade>0</costeUpgrade>
                    <bonificacion>0</bonificacion>
                    <descripcionNivel>Sin mejora</descripcionNivel>
                </nivel>
                <nivel id="2">
                    <costeUpgrade>60</costeUpgrade>
                    <bonificacion>15</bonificacion>
                    <descripcionNivel>-15% tiempo maduracion</descripcionNivel>
                </nivel>
                <nivel id="3">
                    <costeUpgrade>150</costeUpgrade>
                    <bonificacion>30</bonificacion>
                    <descripcionNivel>-30% tiempo maduracion</descripcionNivel>
                </nivel>
            </niveles>
        </herramienta>

        <herramienta>
            <nombre>Hoz</nombre>
            <descripcion>Permite obtener mas frutos</descripcion>
            <niveles>
                <nivel id="1">
                    <costeUpgrade>0</costeUpgrade>
                    <bonificacion>0</bonificacion>
                    <descripcionNivel>Sin mejora</descripcionNivel>
                </nivel>
                <nivel id="2">
                    <costeUpgrade>70</costeUpgrade>
                    <bonificacion>1</bonificacion>
                    <descripcionNivel>+1 unidad extra al recolectar</descripcionNivel>
                </nivel>
                <nivel id="3">
                    <costeUpgrade>180</costeUpgrade>
                    <bonificacion>2</bonificacion>
                    <descripcionNivel>+2 unidades extra al recolectar</descripcionNivel>
                </nivel>
            </niveles>
        </herramienta>

    </herramientas>

</datos>
